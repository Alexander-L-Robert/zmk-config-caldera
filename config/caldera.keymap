#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
        keymap {
                compatible = "zmk,keymap";

                /* default layer. Most normal keys here */
                l0_layer {
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |  ESC   |   1    |   2    |   3    |   4    |   5    |     |   6    |   7    |   8    |   9    |   0    |  BKSP  |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |  TAB   |   Q    |   W    |   E    |   R    |   T    |     |   Y    |   U    |   I    |   O    |   P    |   \    |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |  CAPS  |   A    |   S    |   D    |   F    |   G    |     |   H    |   J    |   K    |   L    |   ;    |  ENT   |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |  SHFT  |   Z    |   X    |   C    |   V    |   B    |     |   N    |   M    |   ,    |   .    |   UP   |  APOS  |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |  CTRL  |  ALT   |  GUI   |   L3   |  L1    |  SPC   |     |  SPC   |   L1   |   L2   |  LEFT  |  DOWN  |  RIGHT |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
                        bindings = <
   &kp ESC    &kp N1     &kp N2     &kp N3     &kp N4     &kp N5        &kp N6     &kp N7     &kp N8     &kp N9     &kp N0     &kp BSPC
   &kp TAB    &kp Q      &kp W      &kp E      &kp R      &kp T         &kp Y      &kp U      &kp I      &kp O      &kp P      &kp BSLH
   &kp CAPS   &kp A      &kp S      &kp D      &kp F      &kp G         &kp H      &kp J      &kp K      &kp L      &kp SEMI   &kp RET
   &kp LSHFT  &kp Z      &kp X      &kp C      &kp V      &kp B         &kp N      &kp M      &kp COMMA  &kp DOT    &kp UARW   &kp APOS
   &kp LCTRL  &kp LALT   &kp LGUI   &mo 3      &mo 1      &kp SPACE     &kp SPACE  &mo 1      &mo 2      &kp LARW   &kp DARW   &kp RARW
                        >;
                };

                /* chopped off keys from default layer positioned close to where they normally would be otherwise */
                l1_layer {
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |   `    |        |        |        |        |        |     |        |        |        |        |  MINUS |  EQUAL |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        |        |        |     |        |        |        |        |   [    |   ]    |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        |        |        |     |        |        |        |        |        |        |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |  SHFT  |        |        |        |        |        |     |        |        |        |        |   /    |  SHFT  |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        |        |        |     |        |        |        |        |        |        |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
                        bindings = <
   &trans     &trans     &trans     &trans     &trans     &trans        &trans     &trans     &trans     &trans     &kp MINUS  &kp EQUAL
   &kp GRAVE  &trans     &trans     &trans     &trans     &trans        &trans     &trans     &trans     &trans     &kp LBKT   &kp RBKT
   &trans     &trans     &trans     &trans     &trans     &trans        &trans     &trans     &trans     &trans     &trans     &trans
   &kp LSHFT  &trans     &trans     &trans     &trans     &trans        &trans     &trans     &trans     &trans     &kp FSLH   &kp RSHFT
   &trans     &trans     &trans     &trans     &trans     &trans        &trans     &trans     &trans     &trans     &trans     &trans
                        >;
                };

                /* keypad */
                l2_layer {
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        |        |        |     |        |        |   +    |   /    |   *    |   -    |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        |        |        |     |        |        |  NMLK  |   7    |   8    |   9    |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        |        |        |     |        |        |        |   4    |   5    |   6    |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        |        |        |     |        |        |        |   1    |   2    |   3    |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        |        |        |     |        |        |        |   0    |  DOT   |  ENT   |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
                        bindings = <
   &trans     &trans     &trans     &trans     &trans     &trans        &trans     &trans     &kp KP_PLUS     &kp KP_SLASH   &kp KP_ASTERISK  &kp KP_MINUS
   &trans     &trans     &trans     &trans     &trans     &trans        &trans     &trans     &kp KP_NUMLOCK  &kp KP_N7      &kp KP_N8        &kp KP_N9   
   &trans     &trans     &trans     &trans     &trans     &trans        &trans     &trans     &trans          &kp KP_N4      &kp KP_N5        &kp KP_N6   
   &trans     &trans     &trans     &trans     &trans     &trans        &trans     &trans     &trans          &kp KP_N1      &kp KP_N2        &kp KP_N3   
   &trans     &trans     &trans     &trans     &trans     &trans        &trans     &trans     &trans          &kp KP_N0      &kp KP_DOT       &kp KP_ENTER
                        >;
                };

                /* Uncommon keys: FN, bluetooth pairing profiles, etc. */
                /* BT_CLR clears all existing connections including the connection between the split keyboard's two halves. */
                l3_layer {
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |   F1   |   F2   |   F3   |   F4   |   F5   |   F6   |     |   F7   |   F8   |   F9   |  F10   |  F11   |  F12   |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |  BT1   |  BT2   |  BT3   |  BT4   |  BT5   | BTCLR  |     |  BT1   |  BT2   |  BT3   |  BT4   |  BT5   | BTCLR  |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        |  INS   |  DEL   |     |        |        |        |        |        |        |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        |  HOME  |  END   |     |        |        |        |        |        |        |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
//  |        |        |        |        | PG_UP  | PG_DN  |     |        |        |        |        |        |        |
//  +--------+--------+--------+--------+--------+--------+     +--------+--------+--------+--------+--------+--------+
                        bindings = <
   &kp F1        &kp F2        &kp F3        &kp F4        &kp F5        &kp F6            &kp F7        &kp F8        &kp F9        &kp F10       &kp F11       &kp F12
   &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &bt BT_CLR        &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &bt BT_CLR
   &trans        &trans        &trans        &trans        &kp INS       &kp DEL           &trans        &trans        &trans        &trans        &trans        &trans
   &trans        &trans        &trans        &trans        &kp HOME      &kp END           &trans        &trans        &trans        &trans        &trans        &trans
   &trans        &trans        &trans        &trans        &kp PG_UP     &kp PG_DN         &trans        &trans        &trans        &trans        &trans        &trans
                        >;
                };
        };
};
